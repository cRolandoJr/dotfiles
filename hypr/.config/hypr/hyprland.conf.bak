#║  Configurado por:      RolandoCobis            ║
#║  GitHub:   https://github.com/cRolandoJr       ║
#╚════════════════════════════════════════════════╝

# See https://wiki.hyprland.org/Configuring/Monitors/
monitor = eDP-1,1920x1080@144,0x0,1.0
# See https://wiki.hyprland.org/Configuring/Keywords/ for more
# --- Portales y DBus: exportar entorno y reiniciar en orden ---
exec-once = dbus-update-activation-environment --systemd --all
exec-once = systemctl --user import-environment DISPLAY WAYLAND_DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_DESKTOP
# Reiniciar backends primero, luego el servicio principal
exec-once = systemctl --user stop xdg-desktop-portal xdg-desktop-portal-hyprland; sleep 0.5; systemctl --user start xdg-desktop-portal-hyprland; sleep 0.5; systemctl --user start xdg-desktop-portal
# Execute your favorite apps at launch
exec-once = dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP # for XDPH
exec-once = dbus-update-activation-environment --systemd --all # for XDPH
exec-once = systemctl --user import-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP # for XDPH
exec-once = waybar 
exec-once = swww-daemon
exec-once = hyprctl setcursor Bibata-Modern-Ice 12
#exec-once = hyprpaper
exec-once = xwaylandvideobridge
exec-once = /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 &
exec-once = nm-applet
exec-once = hypridle -c ~/.config/hypr/hypridle.conf
exec-once = dbus-update-activation-environment --systemd --all
exec-once = swaync
exec-once = swayosd-server
# Set programs that you use
$terminal = kitty 
#$fileManager = kitty --class float_kitty -e ranger
$fileManager = dolphin 
$menu = rofi -show drun
$browser = firefox
$wallselect = ~/.config/rofi/wallselect/script.sh
$wifi = ~/.local/bin/rofi-wifi-menu
$music = spotify
$float_terminal = --class:^$(kitty_float) 
#$screenshots = hyprshot -m region -c -o ~/.local/share/screenshots/
# Some default env vars.
env = XCURSOR_SIZE,24
env = XDG_CURRENT_DESKTOP,Hyprland
env = XDG_SESSION_TYPE,xwayland
env = XDG_SESSION_DESKTOP,Hyprland

env = QT_QPA_PLATFORM,xwayland;xcb
env = QT_WAYLAND_DISABLE_WINDOWDECORATION,1
env = QT_AUTO_SCREEN_SCALE_FACTOR,0
env = QT_QPA_PLATFORMTHEME,qt6ct 
env = GIO_EXTRA_MODULES,/usr/lib/gio/modules
xwayland {
    enabled = true
}

# Electron apps
env = ELECTRON_OZONE_PLATFORM_HINT, auto

env = MOZ_ENABLE_WAYLAND,1

# For all categories, see https://wiki.hyprland.org/Configuring/Variables/
input {
    kb_layout = us
    kb_model =
    kb_variant = 
    kb_options = 
    kb_rules = 
    follow_mouse = 1

    touchpad {
        natural_scroll = true 
    }

    sensitivity = 0.7 # -1.0 <-> 1.0, 0 means no modification.
}

general {
    # See https://wiki.hyprland.org/Configuring/Variables/ for more

    gaps_in = 5
    gaps_out = 10
    border_size = 2
    col.active_border = rgba(1793d1ee)
    col.inactive_border = rgba(595959aa)
    resize_on_border = true
    layout = dwindle

    # Please see https://wiki.hyprland.org/Configuring/Tearing/ before you turn this on
    allow_tearing = false
}

decoration {
    shadow {
        enabled = true
        range = 50
        render_power = 9 
        color = rgba(0,0,0,0.7)
    }
    # See https://wiki.hyprland.org/Configuring/Variables/ for more
    rounding = 15
    blur {
        enabled = true
        size = 3
        passes = 1
    }
}

animations {
    enabled = yes

    # Some default animations, see https://wiki.hyprland.org/Configuring/Animations/ for more

    bezier = myBezier, 0.05, 0.9, 0.1, 1.05

    animation = windows, 1, 7, myBezier
    animation = windowsOut, 1, 7, default, popin 80%
    animation = border, 1, 10, default
    animation = borderangle, 1, 8, default
    animation = fade, 1, 7, default
    animation = workspaces, 1, 6, default
}

dwindle {
    # See https://wiki.hyprland.org/Configuring/Dwindle-Layout/ for more
    pseudotile = yes # master switch for pseudotiling. Enabling is bound to mainMod + P in the keybinds section below
    preserve_split = yes # you probably want this
}

master {
    # See https://wiki.hyprland.org/Configuring/Master-Layout/ for more
    #new_is_master = true
    #new_status = master
}

misc {
    # See https://wiki.hyprland.org/Configuring/Variables/ for more
    force_default_wallpaper = -1 # Set to 0 or 1 to disable the anime mascot wallpapers
    disable_hyprland_logo = false
    session_lock_xray = 1
}

xwayland {
    force_zero_scaling = true
}

# Example per-device config
# See https://wiki.hyprland.org/Configuring/Keywords/#executing for more
device {
    name = epic mouse V1
    sensitivity = -0.5
}

# See https://wiki.hyprland.org/Configuring/Window-Rules/ for more
windowrule = stay_focused on match:class rofi
#windowrulev2 = forceinput, class:(wofi)
windowrule {
name = waypaper
match:class = ^$
match:float = true
} 
windowrule = opacity 0.98 0.98 match:class code
windowrule {
name = float_terminal
match:class = ^$(kitty_float)
match:float = true
size = 1450 800
} 
windowrule {
name = nofocus
match:focus = false
match:class = ^$
match:xwayland = true
match:float = true
match:fullscreen = false
match:pin = false
} 

$mainMod = SUPER

# --- Fix xwaylandvideobridge ---

windowrule {
name = xwayland
match:class = xwaylandvideobridge
opacity = 0.0 
no_anim = on 
no_focus = on 
max_size = 1 1 
no_blur = on
}

# Example binds, see https://wiki.hyprland.org/Configuring/Binds/ for more
bind = $mainMod, Return, exec, $terminal # Ejecutar terminal kitty
bind = $mainMod + SHIFT, Return, exec, $float_terminal 
bind = $mainMod, Q, killactive, # Cerramos alguna ventana (activa)
bind = $mainMod, M, exit, # Salimos de Hyprland
bind = $mainMod, E, exec, $fileManager # Ejecutamos el filemanager
bind = $mainMod, V, togglefloating, # Convertir en flotante alguna ventana
bind = $mainMod, Space, exec, $menu # Lanzar menu
bind = $mainMod, P, pseudo, # Convertir en pseudotiled alguna ventana
bind = $mainMod, J, togglesplit, # dwindle
bind = $mainMod, F, exec, $browser # Ejecutar navegador web
#bind = $mainMod, SPACE, exec, wofi --show drun
bind = $mainMod, T, exec, Telegram
bind = $mainMod, TAB, exec, rofi -show window -show icons
bind = $mainMod, W, exec, $wallselect
bind = $mainMod, A, exec, $wifi
bind = $mainMod, D, exec, ~/.config/hypr/scripts/toggle_float.sh
bind = $mainMod, R, fullscreen 
bind = $mainMod, L, exec, hyprlock
bind = $mainMod, S, exec, $music
bind = $mainMod SHIFT, PRINT, exec, hyprshot --clipboard region 
bind = $mainMod, N, exec, swaync-client -t  # abre/cierra el panel
# Captura de pantalla
#bind = $mainMod, Print, exec, grim ~/Pictures/screenshot-$(date +'%Y%m%d-%H%M%S').png # Captura pantalla completa
bind = $mainMod + SHIFT, Print, exec, grim -g "$(slurp)" ~/Pictures/screenshot-$(date +'%Y%m%d-%H%M%S').png # Captura área seleccionada
bind = $mainMod + CTRL, Print, exec, grim -g "$(slurp)" - | wl-copy # Captura área, copiar al portapapeles
bind = $mainMod, Print, exec, grim -g "$(slurp)" - | swappy -f - # Captura área y editar antes de guardar

# Move focus with mainMod + arrow keys
bind = $mainMod, left, movefocus, l
bind = $mainMod, right, movefocus, r
bind = $mainMod, up, movefocus, u
bind = $mainMod, down, movefocus, d

# Switch workspaces with mainMod + [0-9]
bind = $mainMod, 1, workspace, 1
bind = $mainMod, 2, workspace, 2
bind = $mainMod, 3, workspace, 3
bind = $mainMod, 4, workspace, 4
bind = $mainMod, 5, workspace, 5
bind = $mainMod, 6, workspace, 6
bind = $mainMod, 7, workspace, 7
bind = $mainMod, 8, workspace, 8
bind = $mainMod, 9, workspace, 9
bind = $mainMod, 0, workspace, 10

# Move active window to a workspace with mainMod + SHIFT + [0-9]
bind = $mainMod SHIFT, 1, movetoworkspace, 1
bind = $mainMod SHIFT, 2, movetoworkspace, 2
bind = $mainMod SHIFT, 3, movetoworkspace, 3
bind = $mainMod SHIFT, 4, movetoworkspace, 4
bind = $mainMod SHIFT, 5, movetoworkspace, 5
bind = $mainMod SHIFT, 6, movetoworkspace, 6
bind = $mainMod SHIFT, 7, movetoworkspace, 7
bind = $mainMod SHIFT, 8, movetoworkspace, 8
bind = $mainMod SHIFT, 9, movetoworkspace, 9
bind = $mainMod SHIFT, 0, movetoworkspace, 10
# Volume control
#binde = , xf86audioraisevolume, exec, wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+ --limit 1.5
#binde = , xf86audiolowervolume, exec, wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
#binde = , Xf86AudioMute, exec, wpctl set-mute  @DEFAULT_AUDIO_SINK@ toggle

binde = , XF86AudioRaiseVolume, exec, swayosd-client --output-volume raise
binde = , XF86AudioLowerVolume, exec, swayosd-client --output-volume lower
binde = , XF86AudioMute, exec, swayosd-client --output-volume mute-toggle

bindl = , xf86audionext, exec, playerctl next
bindl = , xf86audioplay, exec, playerctl play-pause
bindl = , xf86audioprev, exec, playerctl previous

# Brightness control
#bindel = , XF86MonBrightnessUp, exec, brightnessctl set +5%
#bindel = , XF86MonBrightnessDown, exec, brightnessctl set 5%-
bind = , XF86MonBrightnessUp, exec, swayosd-client --brightness raise
bind = , XF86MonBrightnessDown, exec, swayosd-client --brightness lower
# ScreenShot
bind = , Print, exec, hyprshot -m output --clipboard-only

# Example special workspace (scratchpad)
#bind = $mainMod ALT, S, togglespecialworkspace, magic
#bind = $mainMod SHIFT, S, movetoworkspace, special:magic

# Scroll through existing workspaces with mainMod + scroll
bind = $mainMod, mouse_down, workspace, e+1
bind = $mainMod, mouse_up, workspace, e-1

# Move/resize windows with mainMod + LMB/RMB and dragging
bindm = $mainMod, mouse:272, movewindow
bindm = $mainMod, mouse:273, resizewindow
#xwayland { enabled = true } hyprctl reload pgrep -a Xwayland echo wayland

# --- PANEL LATERAL (SwayNC) ---

plugin {
    hyprexpo {
        columns = 3
        gap_size = 5
        bg_col = rgb(111111)
        workspace_method = center current # [center/first] [workspace] e.g. first 1 or center m+1

        enable_gesture = true # gestos para laptop
        #gesture_fingers = 3  # 3 dedos
        #gesture_distance = 300 # cuan largo es el swipe
        #gesture_positive = true # positivo = swipe abajo. falso = swipe arriba.
    }
}
