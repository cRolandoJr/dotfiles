/* Global Rofi theme (Rofi 2.0.0)
 * - Azul Nix, limpio, moderno
 * - Corrige selector: element-icon (no "element icon")
 * - Alpha al final: #RRGGBBAA (según tu rofi 2.0.0)
 * - Mantiene launcher normal (con texto). Tu wallpaper picker debe usar su propio -theme.
 */

configuration {
    display-drun: "Applications:";
    display-run:  "Run:";
    display-window: "Windows:";
    drun-display-format: "{icon} {name}";
    font: "JetBrainsMono Nerd Font Medium 10";
    modi: "window,run,drun,ssh,keys,filebrowser";
    show-icons: true;
    icon-theme: "Papirus";
    terminal: "kitty";
}

* {
    /* Palette */
    bg:         #0b1220;
    bg-alt:     #0f1a2e;
    fg:         #d7e3ff;
    fg-alt:     #9fb4d9;

    accent:     #7aa2f7;
    accent2:    #00A2FF;

    /* Transparent variants (RGBA: #RRGGBBAA) */
    win-bg:     #0b1220cc;
    panel-bg:   #0f1a2ecc;
    sel-bg:     #0f1a2ee6;
    hint-bg:    #0f1a2e99;

    background-color: transparent;
    text-color: @fg;

    /* Spacing defaults */
    margin: 0;
    padding: 0;
    spacing: 0;
}

/* Window */
window {
    location: center;
    anchor: center;
    fullscreen: false;

    width: 40%;
    border: 0px;
    border-color: @accent;
    border-radius: 16px;

    background-color: @win-bg;
}

/* Main layout */
mainbox {
    padding: 14px;
    spacing: 12px;
    children: [ "inputbar", "message", "listview" ];
}

/* Input */
inputbar {
    background-color: @panel-bg;
    border-radius: 14px;
    padding: 10px;
    spacing: 10px;
    children: [ "prompt", "entry" ];
}

prompt {
    enabled: true;
    text-color: @accent2;
    background-color: transparent;
}

entry {
    background-color: transparent;
    text-color: @fg;
    placeholder: "Buscar…";
    placeholder-color: @fg-alt;
    padding: 0px;
}

/* Optional message line */
message {
    background-color: transparent;
}

textbox {
    background-color: @hint-bg;
    text-color: @fg-alt;
    border-radius: 12px;
    padding: 10px;
}

/* List */
listview {
    background-color: transparent;
    columns: 1;
    lines: 8;
    fixed-height: true;

    spacing: 6px;
    scrollbar: true;
    padding: 2px;
}

/* Elements */
element {
    background-color: transparent;
    border-radius: 12px;
    padding: 10px;
    spacing: 10px;

    border: 1px;
    border-color: transparent;
}

element normal.normal {
    background-color: transparent;
}

element selected.normal {
    background-color: @sel-bg;
    border-color: @accent2;
}

element-text {
    background-color: transparent;
    text-color: @fg;
    vertical-align: 0.5;
}

element-text selected.normal {
    text-color: @fg;
}

element-icon {
    size: 22px;
}

/* Scrollbar */
scrollbar {
    width: 6px;
    handle-width: 6px;
    background-color: transparent;
    handle-color: @hint-bg;
    border-radius: 10px;
}

/* Separators (if enabled by mode) */
separator {
    background-color: transparent;
    text-color: @fg-alt;
}

/* Buttons (some scripts/modes use them) */
button {
    background-color: @panel-bg;
    text-color: @fg;
    border-radius: 12px;
    padding: 8px 10px;
}

button selected {
    background-color: @sel-bg;
    text-color: @fg;
    border: 2px;
    border-color: @accent2;
}
