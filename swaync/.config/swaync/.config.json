{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "layer": "overlay",
  "positionX": "right",
  "positionY": "top",
  "control-center-margin-top": 8,
  "control-center-margin-right": 8,
  "control-center-margin-bottom": 8,
  "control-center-margin-left": 8,
  "control-center-width": 420,
  "control-center-height": 600,
  "notification-icon-size": 48,
  "notification-body-image-height": 120,
  "notification-body-image-width": 200,
  "timeout": 5000,
  "timeout-low": 4000,
  "timeout-critical": 0,
  "widgets": [
    "title",
    "dnd",
    "mpris",
    "volume",
    "notifications",
    "buttons"
  ],
  "widget-config": {
    "title": {
      "text": "Notificaciones"
    },
    "dnd": {
      "text": "No molestar"
    },
    "mpris": {
      "player-icons": true,
      "primary-player": "spotify",
      "max-title-length": 60,
      "max-artist-length": 40,
      "max-album-length": 40,
      "image-size": 96,
      "image-radius": 8,
      "show-position": true
    },
    "buttons": {
      "buttons": [
        { "label": "⏼ DND", "action": "swaync-client -d", "class": "dnd-btn" },
        { "label": "󰍫 Limpiar", "action": "swaync-client -C", "class": "clear-btn" }
      ]
    }
  }
}
