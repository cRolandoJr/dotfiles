@import "color.css";

* {
  border: none;
  border-radius: 0;
  font-family: "JetbrainsMono Nerd Font";
  font-size: 12px;
  font-weight: bold;
  min-height: 16px;
}

label.module {
    color: @primary;
    padding: 0 0.25em;
}

/* Altura baja: reducir márgenes/padding verticales en TODOS los módulos */
#network, #bluetooth, #pulseaudio, #battery, #backlight, #clock,
#memory, #disk, #cpu, #workspaces, #taskbar {
  margin-top: 1px;
  margin-bottom: 3px;
}
#custom-launcher {
    margin-right: 4px;
}

#custom-previous, #custom-pause, #custom-next {
    margin-left: 6px;
    margin-right: 8px;
    font-size: 16px
}

#tags button.focused {
	color: #99FF33;
    border-left: 2px solid #FF8FAD;
    border-right: 2px solid #FF8FAD;
    border-top: 2px solid #FF8FAD;
    border-bottom: 2px solid #FF8FAD;
}


/* La barra en sí */
window#waybar {
    background-color:rgba(36, 39, 48, 0.2);
    /*background-color: #1A1B26;*/
    border-radius: 0px;
    margin-top: 4px;
}
#workspaces button {
  all: initial;
  /* Remove GTK theme values (waybar #1351) */
  min-width: 0;
  /* Fix weird spacing in materia (waybar #450) */
  box-shadow: inset 0 -3px transparent;
  /* Use box-shadow instead of border so the text isn't offset */
  padding: 6px 18px;
  margin: 6px 3px;
  border-radius: 4px;
  background-color: rgba(20, 120, 209, 0.5) /*#1e1e2e*/;
  /*color: rgba(255,255,255,1)#cdd6f4;*/
}

#workspaces button.active { 
    background-color: rgba(220, 220, 220, 0.4);
    color : rgba(0,0,0,1);
}

#window, #clock, #network, #pulseaudio, #battery, #backlight, #memory, #disk, #cpu, #workspaces button {
    background-color: rgba(240, 240, 240, 0.8);
    color: rgba(0,0,0,1);
} 

#window, #clock, #network, #pulseaudio, #battery, #backlight, #memory, #disk, #cpu {
 border-radius: 4px;
  margin: 6px 3px ;
  padding: 6px 12px;
  /*color: #F1F1F1;*/
}
/* Bluetooth con menos tamaño */
#bluetooth {
  padding: 0 4px;
  margin: 4px;
  border-radius: 14px;
  font-size: 18px; 
  font-weight: bold;
  background: #1467b5;
}

