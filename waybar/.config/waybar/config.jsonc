{
  "layer": "top",
  "height": 28,
  "margin-top": 4,
  "margin-bottom": 0,
  // margin-left/right: 7 βÜ£ matchea hyprland gaps_out:7 de las ventanas.
  // Los chips pegados al borde del bar quedan alineados con el borde de
  // las ventanas tiled.
  // OJO: no fijar "width" (waybar lo autocalcula como screen - margins).
  "margin-left": 7,
  "margin-right": 7,
  "reload_on_change": true,
  "reload_style_on_change": true,

  "modules-left": ["custom/nixos", "hyprland/workspaces", "mpris"],
  "modules-center": ["hyprland/window"],
  "modules-right": [
    "custom/layout",
    "temperature",
    "pulseaudio",
    "network",
    "battery",
    "custom/power-profile",
    "clock",
  ],

  // βîÄβîÄβîÄ NixOS chip βÄî gen + flake status βîÄβîÄβîÄβîÄβîÄβîÄβîÄβîÄβîÄβîÄβîÄβîÄβîÄβîÄβîÄβîÄβîÄβîÄβîÄβîÄβîÄβîÄβîÄβîÄβîÄβîÄβîÄβîÄβîÄβîÄβîÄβîÄβîÄβîÄβîÄβîÄβîÄ
  //   Click izq βÜ£ hub | Click der βÜ£ kitty en el flake dir (para resolver dirty)
  "custom/nixos": {
    "exec": "$HOME/.config/hypr/scripts/waybar-nixos-status.sh",
    "return-type": "json",
    "interval": 10,
    "format": "{}",
    "tooltip": true,
    "on-click": "~/.config/hypr/scripts/hub-toggle.sh",
    "on-click-right": "kitty --working-directory ~/projects/nix-config",
  },

  "hyprland/window": {
    "max-length": 60,
    "separate-outputs": true,
    "tooltip": false,
    "rewrite": {
      "(.*) βÄî Mozilla Firefox": "σΑàΙ  $1",
      "(.*) βÄî Chromium": "σΑä·  $1",
      "(.*)kitty(.*)": "terminal",
      "(.*)nvim(.*)": "nvim",
      "(.*)Code(.*)": "σΑ®û  code",
      "(.*)Discord(.*)": "σΑô·  discord",
      "(.*)Telegram(.*)": "telegram",
      "": "escritorio",
    },
  },

  "pulseaudio": {
    "tooltip": false,
    "scroll-step": 5,
    "format": "{icon} {volume}%",
    "format-muted": "σΑùü {volume}%",
    "on-click": "~/.config/hypr/scripts/hub-toggle.sh",
    "on-click-right": "pavucontrol",
    "on-scroll-up": "wpctl set-volume -l 1.5 @DEFAULT_AUDIO_SINK@ 5%+",
    "on-scroll-down": "wpctl set-volume -l 1.5 @DEFAULT_AUDIO_SINK@ 5%-",
    "format-icons": {
      "default": ["σΑïΩ", "σΑ•Ä", "σΑïΨ"],
    },
  },

  // Control de Spotify. Click=play/pause, scroll=next/prev, der=abrir Spotify.
  // Desaparece sin player (format-stopped vacΟ≠o).
  "mpris": {
    "player": "spotify",
    "format": "σΑêä  {title}",
    "format-paused": "σΑèΛ  {title}",
    "format-stopped": "",
    "max-length": 28,
    "tooltip-format": "{title}\n{artist} ¬Ζ {album}",
    "on-click": "playerctl --player=spotify play-pause",
    "on-click-right": "$HOME/.config/hypr/scripts/spotify-toggle.sh",
    "on-scroll-up": "playerctl --player=spotify next",
    "on-scroll-down": "playerctl --player=spotify previous",
  },

  // Sin persistent-workspaces: muestra solo los ocupados + el activo (dinΟΓmico).
  "hyprland/workspaces": {
    "on-click": "activate",
    // {id} = nΟΚmero del ws. El CSS oculta el label en los inactivos (quedan
    // dots) y solo lo revela en el activo.
    "format": "{id}",
  },

  // Cantidad de ventanas del workspace activo (el tape en scrolling).
  // Event-driven vΟ≠a socket Hyprland; ver waybar-wscount.sh.
  "custom/wscount": {
    "exec": "stdbuf -oL $HOME/.config/hypr/scripts/waybar-wscount.sh",
    "return-type": "json",
    "format": "{}",
    "restart-interval": 3,
    "tooltip": true,
  },

  "network": {
    "tooltip": true,
    "format-wifi": "{icon}",
    "tooltip-format-wifi": "{essid}\nSignal: {signalStrength}% ({signaldBm} dBm) @ {frequency} GHz\nIP: {ipaddr}/{cidr}  GW: {gwaddr}\nβÜ™ {bandwidthDownBytes}/s   βÜë {bandwidthUpBytes}/s",
    "tooltip-format-ethernet": "{ifname}\nIP: {ipaddr}/{cidr}  GW: {gwaddr}\nβÜ™ {bandwidthDownBytes}/s   βÜë {bandwidthUpBytes}/s",
    "tooltip-format-disconnected": "Disconnected",
    "format-ethernet": "",
    "format-icons": { "wifi": ["σΑΛ·", "σΑΛü", "σΑΛΔ", "σΑΛΞ", "σΑΛ®"] },
    "interval": 2,
    "on-click": "~/.config/hypr/scripts/hub-toggle.sh",
    "on-click-right": "nm-connection-editor",
    "on-click-middle": "nmcli radio wifi off || nmcli radio wifi on",
  },

  "temperature": {
    // Anclado al CPU AMD (k10temp) vΟ≠a PCI BDF estable, no thermal_zone0
    // (que puede reasignarse entre reboots).
    "hwmon-path-abs": "/sys/devices/pci0000:00/0000:00:18.3/hwmon",
    "input-filename": "temp1_input",
    "critical-threshold": 90,
    "interval": 2,
    "tooltip": false,
    "format-critical": "{temperatureC}¬ΑC {icon}",
    "format": "{temperatureC}¬ΑC {icon}",
    "format-icons": ["", "", ""],
    "on-click": "~/.config/hypr/scripts/hub-toggle.sh",
  },

  "battery": {
    "states": { "good": 95, "warning": 30, "critical": 10 },
    "format": "{icon} {capacity}%",
    "format-charging": "<span color='#34d399'>σΑ²³ </span>{capacity}%",
    "format-alt": "<span color='#cdd6f4'>{time}</span> {icon}",
    "format-icons": [
      "<span color='#f87171'>σΑ¹Κ</span>",
      "<span color='#f87171'>σΑ¹Μ</span>",
      "<span color='#fb923c'>σΑ¹Φ</span>",
      "<span color='#fb923c'>σΑ¹Ϋ</span>",
      "<span color='#00B4D8E6'>σΑ¹Ψ</span>",
      "<span color='#00B4D8E6'>σΑ¹Ω</span>",
      "<span color='#00B4D8E6'>σΑ²Ä</span>",
      "<span color='#00B4D8E6'>σΑ²¹</span>",
      "<span color='#00B4D8E6'>σΑ²²</span>",
      "<span color='#00B4D8E6'>σΑ¹Ι</span>",
    ],
    "on-click": "~/.config/hypr/scripts/hub-toggle.sh",
  },

  "clock": {
    "tooltip": false,
    "interval": 60,
    "timezone": "America/Argentina/Buenos_Aires",
    "format": "σΑΞî {:%H:%M}",
    "on-click": "~/.config/hypr/scripts/hub-toggle.sh",
  },

  "custom/layout": {
    "exec": "stdbuf -oL $HOME/.config/hypr/scripts/waybar-layout.sh",
    "return-type": "json",
    "format": "{}",
    "restart-interval": 3,
    "on-click": "hyprctl switchxkblayout current next",
  },

  // power-profile custom: Ο≠cono refleja el modo activo; click cicla los 3 perfiles.
  // Refresh inmediato vΟ≠a signal SIGRTMIN+10 (script emite pkill al final).
  "custom/power-profile": {
    "exec": "case $(powerprofilesctl get) in performance) echo '<span color=\"#f87171\">σ±™û</span>';; power-saver) echo '<span color=\"#34d399\">σΑ¹Ψ</span>';; *) echo '<span color=\"#00b4d8\">σΑ¨Σ</span>';; esac",
    "interval": 5,
    "signal": 10,
    "tooltip": true,
    "tooltip-format": "Power profile",
    "on-click": "$HOME/.config/hypr/scripts/toggle-power-profile.sh",
  },
}
