{
  "layer": "top",
  "height": 28,
  "margin-top": 2,
  "margin-bottom": 0,
  // margin-left/right: 7 → matchea hyprland gaps_out:7 de las ventanas.
  // Los chips pegados al borde del bar quedan alineados con el borde de
  // las ventanas tiled.
  // OJO: no fijar "width" (waybar lo autocalcula como screen - margins).
  "margin-left": 7,
  "margin-right": 7,
  "reload_on_change": true,
  "reload_style_on_change": true,

  "modules-left": ["custom/nixos", "hyprland/workspaces", "mpris"],
  "modules-center": ["hyprland/window"],
  // Orden: controles interactivos (layout/volumen/idle/perfil) → estado
  // pasivo (temp/batería) → reloj como ancla → tray al borde.
  "modules-right": [
    "custom/layout",
    "pulseaudio",
    "idle_inhibitor",
    "custom/power-profile",
    "temperature",
    "battery",
    "clock",
    "tray",
  ],

  // ─── NixOS chip — gen + flake status ─────────────────────────────────────
  //   Click izq → hub | Click der → foot en el flake dir (para resolver dirty)
  "custom/nixos": {
    "exec": "$HOME/.config/hypr/scripts/waybar-nixos-status.sh",
    "return-type": "json",
    "interval": 10,
    "format": "{}",
    "tooltip": true,
    "on-click": "~/.config/hypr/scripts/hub-toggle.sh",
    "on-click-right": "foot --working-directory ~/projects/nix-config",
  },

  "hyprland/window": {
    "max-length": 60,
    "separate-outputs": true,
    "tooltip": false,
    "rewrite": {
      "(.*) — Mozilla Firefox": "󰈹  $1",
      "(.*) — Chromium": "󰊯  $1",
      "(.*)foot(.*)": "terminal",
      "(.*)nvim(.*)": "nvim",
      "(.*)Code(.*)": "󰨞  code",
      "(.*)Discord(.*)": "󰙯  discord",
      "(.*)Telegram(.*)": "telegram",
      "": "escritorio",
    },
  },

  "pulseaudio": {
    "tooltip": false,
    "scroll-step": 5,
    "format": "{icon} {volume}%",
    "format-muted": "󰝟 {volume}%",
    "on-click": "~/.config/hypr/scripts/hub-toggle.sh",
    "on-click-right": "pavucontrol",
    "on-scroll-up": "wpctl set-volume -l 1.5 @DEFAULT_AUDIO_SINK@ 5%+",
    "on-scroll-down": "wpctl set-volume -l 1.5 @DEFAULT_AUDIO_SINK@ 5%-",
    "format-icons": {
      "default": ["󰕿", "󰖀", "󰕾"],
    },
  },

  // Control de Spotify. Click=play/pause, scroll=next/prev, der=abrir Spotify.
  // Desaparece sin player (format-stopped vacío).
  "mpris": {
    "player": "spotify",
    "format": "󰐊  {title}",
    "format-paused": "󰏤  {title}",
    "format-stopped": "",
    "max-length": 28,
    "tooltip-format": "{title}\n{artist} · {album}",
    "on-click": "playerctl --player=spotify play-pause",
    "on-click-right": "$HOME/.config/hypr/scripts/spotify-toggle.sh",
    "on-scroll-up": "playerctl --player=spotify next",
    "on-scroll-down": "playerctl --player=spotify previous",
  },

  // Sin persistent-workspaces: muestra solo los ocupados + el activo (dinámico).
  "hyprland/workspaces": {
    "on-click": "activate",
    // {id} = número del ws. El CSS oculta el label en los inactivos (quedan
    // dots) y solo lo revela en el activo.
    "format": "{id}",
  },

  "temperature": {
    // Anclado al CPU AMD (k10temp) vía PCI BDF estable, no thermal_zone0
    // (que puede reasignarse entre reboots).
    "hwmon-path-abs": "/sys/devices/pci0000:00/0000:00:18.3/hwmon",
    "input-filename": "temp1_input",
    "critical-threshold": 90,
    "interval": 2,
    "tooltip": false,
    "format-critical": "{icon} {temperatureC}°C",
    "format": "{icon} {temperatureC}°C",
    "format-icons": ["󰔏"],
    "on-click": "~/.config/hypr/scripts/hub-toggle.sh",
  },

  "battery": {
    "states": { "good": 95, "warning": 30, "critical": 10 },
    "format": "{icon} {capacity}%",
    "format-charging": "<span color='#34d399'>󰂄 </span>{capacity}%",
    "format-alt": "<span color='#cdd6f4'>{time}</span> {icon}",
    "format-icons": [
      "<span color='#f87171'>󰁺</span>",
      "<span color='#f87171'>󰁻</span>",
      "<span color='#fb923c'>󰁼</span>",
      "<span color='#fb923c'>󰁽</span>",
      "<span color='#00B4D8E6'>󰁾</span>",
      "<span color='#00B4D8E6'>󰁿</span>",
      "<span color='#00B4D8E6'>󰂀</span>",
      "<span color='#00B4D8E6'>󰂁</span>",
      "<span color='#00B4D8E6'>󰂂</span>",
      "<span color='#00B4D8E6'>󰁹</span>",
    ],
    "on-click": "~/.config/hypr/scripts/hub-toggle.sh",
  },

  "clock": {
    "tooltip": true,
    "tooltip-format": "{:%A %d de %B de %Y}",
    "locale": "es_AR.UTF-8",
    "interval": 60,
    "timezone": "America/Argentina/Buenos_Aires",
    "format": "󰥔 {:%H:%M}",
    "on-click": "~/.config/hypr/scripts/hub-toggle.sh",
  },

  "tray": {
    "icon-size": 16,
    "spacing": 8,
  },

  // Mantener pantalla despierta (inhibe hypridle mientras está activado).
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": { "activated": "", "deactivated": "" },
    "tooltip-format-activated": "Idle inhibido — la pantalla no se bloquea",
    "tooltip-format-deactivated": "Idle normal",
  },

  "custom/layout": {
    "exec": "stdbuf -oL $HOME/.config/hypr/scripts/waybar-layout.sh",
    "return-type": "json",
    "format": "{}",
    "restart-interval": 3,
    "on-click": "hyprctl switchxkblayout current next",
  },

  // power-profile custom: ícono refleja el modo activo; click cicla los 3 perfiles.
  // Refresh inmediato vía signal SIGRTMIN+10 (script emite pkill al final).
  "custom/power-profile": {
    "exec": "case $(powerprofilesctl get) in performance) echo '<span color=\"#f87171\">󱓞</span>';; power-saver) echo '<span color=\"#34d399\">󰁾</span>';; *) echo '<span color=\"#00b4d8\">󰌪</span>';; esac",
    "interval": 5,
    "signal": 10,
    "tooltip": true,
    "tooltip-format": "Power profile",
    "on-click": "$HOME/.config/hypr/scripts/toggle-power-profile.sh",
  },
}
